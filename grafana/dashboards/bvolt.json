      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "dfh2uirlztzi8e"
          },
          "query": "import \"array\"\n\npv = from(bucket: \"core\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_state\")\n  |> filter(fn: (r) => r[\"_field\"] == \"pv_power\")\n  |> filter(fn: (r) => r[\"asset_id\"] == \"inverter_1\" or r[\"asset_id\"] == \"inverter_2\")\n  |> last()\n  |> group()\n  |> sum(column: \"_value\")\n  |> findRecord(fn: (key) => true, idx: 0)\n\nsoc = from(bucket: \"core\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_state\")\n  |> filter(fn: (r) => r[\"_field\"] == \"battery_soc\")\n  |> filter(fn: (r) => r[\"asset_id\"] == \"inverter_1\" or r[\"asset_id\"] == \"inverter_2\")\n  |> last()\n  |> group()\n  |> mean(column: \"_value\")\n  |> findRecord(fn: (key) => true, idx: 0)\n\nload = from(bucket: \"core\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_state\")\n  |> filter(fn: (r) => r[\"_field\"] == \"total_load_power\")\n  |> filter(fn: (r) => r[\"asset_id\"] == \"inverter_1\" or r[\"asset_id\"] == \"inverter_2\")\n  |> last()\n  |> group()\n  |> sum(column: \"_value\")\n  |> findRecord(fn: (key) => true, idx: 0)\n\ngrid = from(bucket: \"core\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_state\")\n  |> filter(fn: (r) => r[\"_field\"] == \"total_grid_power\")\n  |> filter(fn: (r) => r[\"asset_id\"] == \"inverter_1\" or r[\"asset_id\"] == \"inverter_2\")\n  |> last()\n  |> group()\n  |> sum(column: \"_value\")\n  |> findRecord(fn: (key) => true, idx: 0)\n\narray.from(rows: [\n  {id: \"pv\", title: \"PV power\", subtitle: \"Inverter 1 + 2\", mainstat: float(v: pv._value), secondarystat: \"W\", color: \"#EAB839\", nodeRadius: 45.0},\n  {id: \"ems\", title: \"EMS state\", subtitle: \"Controller\", mainstat: 0.0, secondarystat: \"active\", color: \"#73BF69\", nodeRadius: 30.0},\n  {id: \"battery\", title: \"Battery SoC\", subtitle: \"Average state\", mainstat: float(v: soc._value), secondarystat: \"%\", color: \"#5794F2\", nodeRadius: 45.0},\n  {id: \"grid\", title: \"Total grid power\", subtitle: \"Inverter 1 + 2\", mainstat: float(v: grid._value), secondarystat: \"W\", color: \"#FF9830\", nodeRadius: 45.0},\n  {id: \"load\", title: \"Total load power\", subtitle: \"Inverter 1 + 2\", mainstat: float(v: load._value), secondarystat: \"W\", color: \"#F2495C\", nodeRadius: 45.0}\n])",
          "refId": "nodes"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "dfh2uirlztzi8e"
          },
          "query": "import \"array\"\n\npv = from(bucket: \"core\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_state\")\n  |> filter(fn: (r) => r[\"_field\"] == \"pv_power\")\n  |> filter(fn: (r) => r[\"asset_id\"] == \"inverter_1\" or r[\"asset_id\"] == \"inverter_2\")\n  |> last()\n  |> group()\n  |> sum(column: \"_value\")\n  |> findRecord(fn: (key) => true, idx: 0)\n\nsoc = from(bucket: \"core\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_state\")\n  |> filter(fn: (r) => r[\"_field\"] == \"battery_soc\")\n  |> filter(fn: (r) => r[\"asset_id\"] == \"inverter_1\" or r[\"asset_id\"] == \"inverter_2\")\n  |> last()\n  |> group()\n  |> mean(column: \"_value\")\n  |> findRecord(fn: (key) => true, idx: 0)\n\nload = from(bucket: \"core\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_state\")\n  |> filter(fn: (r) => r[\"_field\"] == \"total_load_power\")\n  |> filter(fn: (r) => r[\"asset_id\"] == \"inverter_1\" or r[\"asset_id\"] == \"inverter_2\")\n  |> last()\n  |> group()\n  |> sum(column: \"_value\")\n  |> findRecord(fn: (key) => true, idx: 0)\n\ngrid = from(bucket: \"core\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"inverter_state\")\n  |> filter(fn: (r) => r[\"_field\"] == \"total_grid_power\")\n  |> filter(fn: (r) => r[\"asset_id\"] == \"inverter_1\" or r[\"asset_id\"] == \"inverter_2\")\n  |> last()\n  |> group()\n  |> sum(column: \"_value\")\n  |> findRecord(fn: (key) => true, idx: 0)\n\narray.from(rows: [\n  {id: \"pv-ems\", source: \"pv\", target: \"ems\", mainstat: float(v: pv._value), secondarystat: \"PV to EMS\", thickness: 3.0, color: \"#EAB839\"},\n  {id: \"ems-battery\", source: \"ems\", target: \"battery\", mainstat: float(v: soc._value), secondarystat: \"Battery SoC\", thickness: 2.0, color: \"#5794F2\"},\n  {id: \"ems-grid\", source: \"ems\", target: \"grid\", mainstat: float(v: grid._value), secondarystat: \"Grid exchange\", thickness: 2.0, color: \"#FF9830\"},\n  {id: \"ems-load\", source: \"ems\", target: \"load\", mainstat: float(v: load._value), secondarystat: \"Load supply\", thickness: 2.0, color: \"#F2495C\"}\n])",
          "refId": "edges"
        }
