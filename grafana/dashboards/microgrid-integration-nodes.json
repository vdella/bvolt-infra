      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "efgzxzei93i80a"
          },
          "query": "import \"array\"\n\npv = from(bucket: \"microgrid\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"lab\")\n  |> filter(fn: (r) => r[\"abstract_data_storage\"] == \"reducer\")\n  |> filter(fn: (r) => r[\"_field\"] == \"reduced_pv_array_power\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\nsoc = from(bucket: \"microgrid\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"lab\")\n  |> filter(fn: (r) => r[\"equipment\"] == \"inverter1\")\n  |> filter(fn: (r) => r[\"_field\"] == \"battery_soc\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\nload = from(bucket: \"microgrid\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"lab\")\n  |> filter(fn: (r) => r[\"abstract_data_storage\"] == \"reducer\")\n  |> filter(fn: (r) => r[\"_field\"] == \"reduced_total_load_power\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\ngrid = from(bucket: \"microgrid\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"lab\")\n  |> filter(fn: (r) => r[\"abstract_data_storage\"] == \"reducer\")\n  |> filter(fn: (r) => r[\"_field\"] == \"reduced_total_grid_power\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\narray.from(rows: [\n  {id: \"pv\", title: \"PV Array\", subtitle: \"Generation\", mainstat: float(v: pv._value), secondarystat: \"W\", color: \"#EAB839\", nodeRadius: 45.0},\n {id: \"ems\", title: \"MPC-EMS\", subtitle: \"Controller\", mainstat: 0.0, secondarystat: \"active\", color: \"#73BF69\", nodeRadius: 30.0}\n  {id: \"battery\", title: \"Battery\", subtitle: \"Storage\", mainstat: float(v: soc._value), secondarystat: \"%\", color: \"#5794F2\", nodeRadius: 45.0},\n  {id: \"grid\", title: \"Grid\", subtitle: \"Utility\", mainstat: float(v: grid._value), secondarystat: \"W\", color: \"#FF9830\", nodeRadius: 45.0},\n  {id: \"load\", title: \"Load\", subtitle: \"Consumption\", mainstat: float(v: load._value), secondarystat: \"W\", color: \"#F2495C\", nodeRadius: 45.0}\n])",
          "refId": "nodes"
        },
        {
          "datasource": {
            "type": "influxdb",
            "uid": "efgzxzei93i80a"
          },
          "query": "import \"array\"\n\npv = from(bucket: \"microgrid\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"lab\")\n  |> filter(fn: (r) => r[\"abstract_data_storage\"] == \"reducer\")\n  |> filter(fn: (r) => r[\"_field\"] == \"reduced_pv_array_power\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\nsoc = from(bucket: \"microgrid\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"lab\")\n  |> filter(fn: (r) => r[\"equipment\"] == \"inverter1\")\n  |> filter(fn: (r) => r[\"_field\"] == \"battery_soc\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\nload = from(bucket: \"microgrid\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"lab\")\n  |> filter(fn: (r) => r[\"abstract_data_storage\"] == \"reducer\")\n  |> filter(fn: (r) => r[\"_field\"] == \"reduced_total_load_power\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\ngrid = from(bucket: \"microgrid\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r[\"_measurement\"] == \"lab\")\n  |> filter(fn: (r) => r[\"abstract_data_storage\"] == \"reducer\")\n  |> filter(fn: (r) => r[\"_field\"] == \"reduced_total_grid_power\")\n  |> last()\n  |> findRecord(fn: (key) => true, idx: 0)\n\narray.from(rows: [\n  {id: \"pv-ems\", source: \"pv\", target: \"ems\", mainstat: float(v: pv._value), secondarystat: \"PV to EMS\", thickness: 3.0, color: \"#EAB839\"},\n  {id: \"ems-battery\", source: \"ems\", target: \"battery\", mainstat: float(v: soc._value), secondarystat: \"Battery SoC\", thickness: 2.0, color: \"#5794F2\"},\n  {id: \"ems-grid\", source: \"ems\", target: \"grid\", mainstat: float(v: grid._value), secondarystat: \"Grid exchange\", thickness: 2.0, color: \"#FF9830\"},\n  {id: \"ems-load\", source: \"ems\", target: \"load\", mainstat: float(v: load._value), secondarystat: \"Load supply\", thickness: 2.0, color: \"#F2495C\"}\n])\n",
          "refId": "edges"
        }
      ],
      "title": "Inverter 1+2 EMS topology",
      "type": "nodeGraph"
